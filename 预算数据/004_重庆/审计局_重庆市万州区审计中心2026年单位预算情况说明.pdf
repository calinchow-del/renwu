<script type="text/javascript">
    // 显示PDF的一些兼容处理，判断是否可以预览PDF
    function isAcrobatPluginInstall() {
        //下面代码都是处理IE浏览器的情况
        if((window.ActiveXObject)||(navigator.userAgent.indexOf("Trident") > -1)) {
            for(x = 2; x < 10; x++) {
                try {
                    oAcro = eval("new ActiveXObject('PDF.PdfCtrl." + x + "');");
                    if(oAcro) {
                        return true;
                    }
                } catch(e) {}
            }
            try {
                oAcro4 = new ActiveXObject('PDF.PdfCtrl.1');
                if(oAcro4)
                    return true;
            } catch(e) {}
            try {
                oAcro7 = new ActiveXObject('AcroPDF.PDF.1');
                if(oAcro7)
                    return true;
            } catch(e) {}
        }else{
            //chrome和FF、safrai等其他浏览器
            return true;
        }
    }
	// 显示PDF
	if ($('.js-open-pdf').get(0) && $("#fj-num>a").length == 1) {//只有1个附件且为pdf的时候才显示pdf
		var pdfresult=1;
	    var pdfFile = $('.js-open-pdf').data('pdf');
	    var fileType = pdfFile.substring(pdfFile.lastIndexOf('.')+1);
	    if("pdf" == fileType){
		    if(pdfFile!=null&&pdfFile!=''){
		    	$('#htmlcontent').hide();
		        if (pdfresult) {
		        	$('#show-pdf').show();
		            $('#show-pdf').attr('src',pdfFile)
		        } else {
		        	$('#show-download').show();
		            $('.download-pdf').find('a').attr('href',pdfFile)
		        }
		   
		    }
		}
	}
</script>
