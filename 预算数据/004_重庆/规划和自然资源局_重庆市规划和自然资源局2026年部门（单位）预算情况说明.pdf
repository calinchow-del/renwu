function headUrlStatus(url, callbackSuccess, callbackError) {
    var xmlhttp = new XMLHttpRequest()
    xmlhttp.open('HEAD', url, false)
    xmlhttp.onreadystatechange = function(){
        if (xmlhttp.readyState == 4) {
            if (xmlhttp.status == 200) {
                callbackSuccess()
            } else {
                callbackError()
            }
        }
    }
    xmlhttp.send()
    return
}
}
