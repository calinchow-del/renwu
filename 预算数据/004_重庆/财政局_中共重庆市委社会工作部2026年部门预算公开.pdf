    result = $.trim(result);
    var reg = /[`~!@#$%^&*_+<>{}\/'[\]]/im;
    if (reg.test(result)) {
      window.wxc.xcConfirm('您输入的信息包含非法字符!', window.wxc.xcConfirm.typeEnum.info)
      return false;
    }
    if (result == "请输入搜索内容" || result == "" || result == null) {
      window.wxc.xcConfirm('请输入检索条件!', window.wxc.xcConfirm.typeEnum.info)
      return false;
    } else {
      result = result.replace("-", "\-");
      result = result.replace("(", "\(");
      result = result.replace(")", "\)");
    }

