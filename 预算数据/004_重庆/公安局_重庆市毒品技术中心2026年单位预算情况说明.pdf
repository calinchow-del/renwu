    if (xlguidang == "") {
        var guidang = '0';
        if (guidang == 1) {
            $(".guidang-container").css("display", "block");
        } else {
            $(".guidang-container").css("display", "none");
        }
    } else {
        var xlgdtime = '';
        $('.guidang-container .time').text(xlgdtime);
        if (xlguidang == 1) {
            $(".guidang-container").css("display", "block");
        } else {
            $(".guidang-container").css("display", "none");
        }
    }
