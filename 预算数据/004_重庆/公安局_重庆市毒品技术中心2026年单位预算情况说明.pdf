    <script>
        var fzTime = "";
        var now = Date.now();
        if(fzTime != ""){
            fzTime = new Date(fzTime.replace(/-/g, '/'));
            if(fzTime.getTime() < now){
                $(".feizhi").css("display","block");
                $('#yxxVal').html('废止')
            }else {
                $('#yxxVal').html('有效')
            }
        }else {
            $('#yxxVal').html('有效')
        }
    </script>
