         var tmpDate=new Date();
         date = tmpDate.getDate();
         month = tmpDate.getMonth() + 1 ;
         year = tmpDate.getYear();
         hh = tmpDate.getHours();
         mi = tmpDate.getMinutes();
         ss = tmpDate.getSeconds();
         year = year>1900 ? year : year+1900;
         if (hh<10){hh = '0' + hh;}
         if (mi<10){mi = '0' + mi;}
         if (ss<10){ss = '0' + ss;}
         document.write(year + "年" + month + "月" + date + "日&nbsp;");
